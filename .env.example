# Copy this file to ".env" (which is git-ignored) and fill in your own values.
# The dashboard reads these at startup. Nothing here is uploaded anywhere; the
# backend uses the keys locally to fetch data on your behalf.

# --- Alpaca paper-trading credentials (required for live data) ---
# Create a key pair in the Alpaca dashboard under Paper Trading > API Keys:
#   https://app.alpaca.markets/paper/dashboard/overview
# Options data needs the account approved for options (Level 1 is enough for
# reading chains and quotes).
APCA_API_KEY_ID=your_key_id_here
APCA_API_SECRET_KEY=your_secret_key_here

# --- Alpaca hosts (optional; these defaults rarely need changing) ---
APCA_API_BASE_URL=https://paper-api.alpaca.markets
APCA_API_DATA_URL=https://data.alpaca.markets

# --- Local history database (optional) ---
# Where the examined-stock history is stored. Defaults to history.db in the
# project root if left unset.
# HISTORY_DB_PATH=history.db
